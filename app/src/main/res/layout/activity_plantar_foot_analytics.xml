<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF1F4"
    android:orientation="vertical">

    <include layout="@layout/toolbar_view_analytics" />

    <ScrollView
        android:id="@+id/analytics_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/plantar_analytics_info_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#DEE5EC"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_medium"
                    android:lineSpacingExtra="2dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="@string/analytics_zone_description"
                    android:textAlignment="center"
                    android:textColor="#0D3B66"
                    android:textSize="13sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <!-- Heatmap left (14×43 width:height — wider column scales length correctly); controls then donut stacked on right. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="top"
                    android:layoutDirection="ltr"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="0dp"
                    android:weightSum="10">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="5.75"
                        android:minWidth="56dp">

                        <ImageView
                            android:id="@+id/analytics_heatmap_image"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:background="#F0F3F7"
                            android:contentDescription="@string/analytics_heatmap_desc"
                            android:importantForAccessibility="yes"
                            android:padding="0dp"
                            android:scaleType="fitXY"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintDimensionRatio="14:43"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Fixed Space widgets = identical gaps (margins alone looked uneven under gravity). -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/plantar_live_card_edge_gap"
                        android:layout_marginBottom="@dimen/plantar_live_card_edge_gap"
                        android:layout_weight="4.25"
                        android:gravity="top"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start">

                            <Button
                                android:id="@+id/plantar_live_calibrate_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/rounded_blue_button"
                                android:fontFamily="@font/roboto_medium"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="48dp"
                                android:minWidth="148dp"
                                android:paddingHorizontal="26dp"
                                android:paddingTop="11dp"
                                android:paddingBottom="14dp"
                                android:text="@string/calibrate"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textSize="15sp" />

                            <ProgressBar
                                android:id="@+id/plantar_live_calibration_progress"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_gravity="bottom|center_horizontal"
                                android:layout_marginStart="20dp"
                                android:layout_marginEnd="20dp"
                                android:layout_marginBottom="9dp"
                                android:clickable="false"
                                android:focusable="false"
                                android:max="10"
                                android:progress="0"
                                android:progressBackgroundTint="#55FFFFFF"
                                android:progressTint="@android:color/white"
                                android:visibility="gone" />
                        </FrameLayout>

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/plantar_live_section_gap" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_medium"
                                android:letterSpacing="0.02"
                                android:text="@string/plantar_live_label_ataxia_classification"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <Space
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/plantar_live_label_chip_gap" />

                            <TextView
                                android:id="@+id/plantar_live_ataxia_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/status_chip_bg"
                                android:backgroundTint="#24F58433"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center_vertical|center_horizontal"
                                android:minHeight="48dp"
                                android:paddingHorizontal="22dp"
                                android:paddingVertical="11dp"
                                android:text="@string/status_normal"
                                android:textColor="#F58433"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/plantar_live_section_gap" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_medium"
                                android:letterSpacing="0.02"
                                android:text="@string/plantar_live_label_motion_status"
                                android:textColor="#6B7280"
                                android:textSize="13sp" />

                            <Space
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/plantar_live_label_chip_gap" />

                            <TextView
                                android:id="@+id/plantar_live_motion_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/status_chip_bg"
                                android:backgroundTint="#247E3EEA"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center_vertical|center_horizontal"
                                android:minHeight="48dp"
                                android:paddingHorizontal="22dp"
                                android:paddingVertical="11dp"
                                android:text="@string/motion_static"
                                android:textColor="#7E3EEA"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/plantar_live_section_gap" />

                        <com.example.ble_viewer.StepDonutView
                            android:id="@+id/plantar_live_step_donut"
                            android:layout_width="126dp"
                            android:layout_height="126dp"
                            android:layout_gravity="center_horizontal" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#DEE5EC"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginTop="2dp"
                            android:contentDescription="@string/analytics_ataxia_title"
                            android:src="@drawable/ic_circle_alert"
                            app:tint="#0D3B66" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/analytics_ataxia_title"
                            android:textColor="@color/blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="34dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="@string/analytics_ataxia_desc"
                        android:textColor="#0D3B66"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/analytics_steps_consistency"
                            android:textColor="@color/blue"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/analytics_steps_period"
                            android:textColor="#0D3B66"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/stepsConsistencyChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/share_health_report_button"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/analytics_share_health_report"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/background"
                app:cornerRadius="24dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_share_report"
                app:iconPadding="10dp"
                app:iconTint="@null"
                app:rippleColor="#1AFFFFFF"
                app:strokeWidth="0dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/analytics_secure_pdf_note"
                android:textColor="#4A5462"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/nav_foot_overview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_foot_overview"
                android:src="@drawable/ic_foot_overview"
                app:tint="#3F93E9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_foot_overview"
                android:textColor="#3F93E9"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_home"
                android:src="@drawable/ic_nav_home"
                app:tint="#6B7480" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_home"
                android:textColor="#6B7480"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_settings"
                android:src="@drawable/ic_nav_settings"
                app:tint="#6B7480" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_settings"
                android:textColor="#6B7480"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

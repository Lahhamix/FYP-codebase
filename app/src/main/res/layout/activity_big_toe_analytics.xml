<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF1F4"
    android:orientation="vertical">

    <include layout="@layout/toolbar_main" />

    <ScrollView
        android:id="@+id/big_toe_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">



            <TextView
                android:id="@+id/big_toe_info_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#F1F8FD"
                android:fontFamily="@font/roboto_medium"
                android:lineSpacingExtra="2dp"
                android:padding="12dp"
                android:text="@string/big_toe_banner"
                android:textColor="#0A2C4D"
                android:textSize="13sp" />

            <!-- Heart Rate card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#E4E8EE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/dashboard_heart_rate_label"
                            android:src="@drawable/ic_heart_rate"
                            app:tint="#F05A7E" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/dashboard_heart_rate_label"
                            android:textColor="@color/blue"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/big_toe_hr_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/status_chip_bg"
                            android:fontFamily="@font/roboto_medium"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="@string/dashboard_status_normal"
                            android:textColor="@color/blue"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/big_toe_hr_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="-- BPM"
                        android:textColor="@color/blue"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/big_toe_hr_period"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:drawableEnd="@drawable/settings_chevron_right"
                        android:drawablePadding="4dp"
                        android:focusable="true"
                        android:fontFamily="@font/roboto_medium"
                        android:gravity="center_vertical"
                        android:paddingVertical="6dp"
                        android:paddingEnd="2dp"
                        android:text="@string/big_toe_last_4_hours"
                        android:textColor="#6E7785"
                        android:textSize="12sp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/big_toe_hr_chart"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@string/analytics_updated_icon_desc"
                            android:src="@drawable/ic_nav_history"
                            app:tint="#576575" />

                        <TextView
                            android:id="@+id/big_toe_hr_updated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/analytics_updated_waiting"
                            android:textColor="#576575"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/big_toe_hr_range"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/big_toe_hr_range"
                            android:textColor="#576575"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SpO2 card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#E4E8EE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/dashboard_spo2_label"
                            android:src="@drawable/ic_spo2"
                            app:tint="#2D7EEA" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/big_toe_spo2_title"
                            android:textColor="@color/blue"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/big_toe_spo2_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/status_chip_bg"
                            android:fontFamily="@font/roboto_medium"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="@string/dashboard_status_healthy"
                            android:textColor="@color/blue"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/big_toe_spo2_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="-- %"
                        android:textColor="@color/blue"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/big_toe_spo2_period"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:drawableEnd="@drawable/settings_chevron_right"
                        android:drawablePadding="4dp"
                        android:focusable="true"
                        android:fontFamily="@font/roboto_medium"
                        android:gravity="center_vertical"
                        android:paddingVertical="6dp"
                        android:paddingEnd="2dp"
                        android:text="@string/big_toe_last_4_hours"
                        android:textColor="#6E7785"
                        android:textSize="12sp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/big_toe_spo2_chart"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@string/analytics_updated_icon_desc"
                            android:src="@drawable/ic_nav_history"
                            app:tint="#576575" />

                        <TextView
                            android:id="@+id/big_toe_spo2_updated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/analytics_updated_waiting"
                            android:textColor="#576575"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/big_toe_spo2_range"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/big_toe_spo2_range"
                            android:textColor="#576575"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BP Classification (placeholder values; scale matches design) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_bp_card_outer_dashed"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/bp_classification"
                            android:src="@drawable/ic_bp_classification"
                            app:tint="#5A6B7A" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/bp_classification"
                            android:textColor="#5A6B7A"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/big_toe_bp_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_bp_reading_bubble"
                            android:fontFamily="@font/roboto_medium"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="10dp"
                            android:text="@string/big_toe_bp_placeholder"
                            android:textColor="#1E2A36"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="-1dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_bp_scale_caret" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:orientation="horizontal"
                            android:weightSum="3">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_bp_bar_hypo"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center"
                                android:paddingVertical="10dp"
                                android:text="@string/big_toe_bp_hypotension"
                                android:textAllCaps="true"
                                android:textColor="#1565C0"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginHorizontal="2dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_bp_bar_norm"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center"
                                android:paddingVertical="10dp"
                                android:text="@string/big_toe_bp_normal"
                                android:textAllCaps="true"
                                android:textColor="#1B5E3A"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@drawable/bg_bp_bar_hyper"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center"
                                android:paddingVertical="10dp"
                                android:text="@string/big_toe_bp_hypertension"
                                android:textAllCaps="true"
                                android:textColor="#B71C1C"
                                android:textSize="9sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_bp_detail_hypo"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_medium"
                                android:text="@string/big_toe_bp_hypotension"
                                android:textAllCaps="true"
                                android:textColor="#1565C0"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="〜"
                                android:textColor="#1565C0"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/big_toe_bp_detail_hypo_line"
                                android:textColor="#4A5F72"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_bp_detail_norm"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_medium"
                                android:text="@string/big_toe_bp_normal"
                                android:textAllCaps="true"
                                android:textColor="#1B5E3A"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="◎"
                                android:textColor="#2E8B57"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/big_toe_bp_detail_norm_line"
                                android:textColor="#4A5F72"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_bp_detail_hyper"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/roboto_medium"
                                android:text="@string/big_toe_bp_hypertension"
                                android:textAllCaps="true"
                                android:textColor="#B71C1C"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="⚠"
                                android:textColor="#C62828"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/roboto_medium"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/big_toe_bp_detail_hyper_line"
                                android:textColor="#4A5F72"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#E4E8EE"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_medium"
                        android:text="@string/big_toe_what_is_spo2_title"
                        android:textColor="@color/blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/roboto_medium"
                        android:lineSpacingExtra="2dp"
                        android:text="@string/big_toe_what_is_spo2_desc"
                        android:textColor="#6E7785"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/big_toe_share_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/analytics_share_health_report"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                app:backgroundTint="@color/blue"
                app:cornerRadius="18dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_share_report"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@null"
                app:rippleColor="#1AFFFFFF"
                app:strokeWidth="0dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/analytics_secure_pdf_note"
                android:textColor="#7A8DA1"
                android:textSize="11sp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation (3 items) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@android:color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/nav_foot_overview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_foot_overview"
                android:src="@drawable/ic_foot_overview"
                app:tint="#3F93E9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_foot_overview"
                android:textColor="#3F93E9"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_home"
                android:src="@drawable/ic_nav_home"
                app:tint="#6B7480" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_home"
                android:textColor="#6B7480"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_settings"
                android:src="@drawable/ic_nav_settings"
                app:tint="#6B7480" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_settings"
                android:textColor="#6B7480"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>


<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@drawable/rounded_dialog_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/auto_share_missing_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/rubik_medium"
        android:text="@string/settings_auto_share_missing_recipients_title"
        android:textColor="@color/blue"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/auto_share_missing_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="2dp"
        android:fontFamily="@font/roboto_medium"
        android:text="@string/settings_auto_share_missing_recipients_message"
        android:textColor="#5F6D7B"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/auto_share_missing_cancel_button"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="#1D4A7A"
            android:textSize="14sp"
            app:backgroundTint="@android:color/white"
            app:cornerRadius="18dp"
            app:elevation="0dp"
            app:rippleColor="#110D3B66"
            app:strokeColor="#4E7EA8"
            app:strokeWidth="2dp" />

        <View
            android:layout_width="22dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/auto_share_missing_manage_button"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/settings_auto_share_manage_recipients"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#0D3B66"
            app:cornerRadius="18dp"
            app:elevation="0dp"
            app:rippleColor="#1AFFFFFF" />
    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF1F4"
    android:orientation="vertical">

    <include layout="@layout/toolbar_view_analytics" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/big_toe_info_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"

                android:background="@drawable/foot_overview_zone_pill_bg"
                app:cardBackgroundColor="#DEE5EC"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Your ankle swelling is currently within the Normal Range. Measurements are taken every 5 minutes by your smart shoe."
                        android:textColor="#0D3B66"
                        android:textAlignment="center"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Swelling Severity Classification -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Swelling Severity Classification"
                        android:textColor="#0D3B66"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <!-- Gauge Placeholder -->
                    <ImageView
                        android:id="@+id/ankle_gauge"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="8dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/ankle_severity_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="SEVERE LEVEL DETECTED"
                        android:textColor="#EC4D75"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Severity Legend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No swelling risk" android:textSize="12sp" android:textColor="#0D3B66" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Subclinical  " android:textSize="12sp" android:textColor="#0D3B66" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Mild  " android:textSize="12sp" android:textColor="#0D3B66" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Moderate  " android:textSize="12sp" android:textColor="#0D3B66" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Severe  " android:textSize="12sp" android:textColor="#EC4D75" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Immediate clinical attention is advised for severe symptoms."
                        android:textColor="#EC4D75"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Swelling Trend -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Swelling Trend (Last 24 hours)"
                        android:textColor="#0D3B66"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Chart Placeholder -->
                    <ImageView
                        android:id="@+id/ankle_trend_chart"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="8dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Severe"
                        android:textColor="#EC4D75"
                        android:textSize="13sp"
                        android:background="@drawable/foot_overview_zone_pill_bg"
                        android:padding="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Updated 2m ago"
                        android:textColor="#6B7480"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Health Tip -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#FFF9E5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_circle_alert"
                        android:tint="#F7B801" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Health Tip\nRest and elevate your feet. If swelling persists, consult your doctor."
                        android:textColor="#0D3B66"
                        android:textSize="13sp" />


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#DEE5EC"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginTop="2dp"
                            android:contentDescription="What is Edema?"
                            android:src="@drawable/ic_circle_alert"
                            app:tint="#0D3B66" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="What is Edema?"
                            android:textColor="@color/blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="34dp"
                        android:fontFamily="@font/roboto_medium"
                        android:text="Edema is when parts of your body, like your feet or legs, swell up because there is extra fluid inside the tissues. This can happen when you’re injured, have inflammation, or certain health conditions. It can make the skin feel tight and puffy."
                        android:textColor="#0D3B66"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/big_toe_share_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/roboto_medium"
                android:text="@string/analytics_share_health_report"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                app:backgroundTint="@color/blue"
                app:cornerRadius="18dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_share_report"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@null"
                app:rippleColor="#1AFFFFFF"
                app:strokeWidth="0dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/analytics_secure_pdf_note"
                android:textColor="#7A8DA1"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@color/white"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:weightSum="3">

        <LinearLayout
            android:id="@+id/nav_foot_overview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_foot_overview"
                android:src="@drawable/ic_foot_overview"
                app:tint="#3F93E9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_foot_overview"
                android:textColor="#3F93E9"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_home"
                android:src="@drawable/ic_nav_home"
                app:tint="#6B7480" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_home"
                android:textColor="#6B7480"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/nav_settings"
                android:src="@drawable/ic_nav_settings"
                app:tint="#6B7480" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:text="@string/nav_settings"
                android:textColor="#6B7480"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

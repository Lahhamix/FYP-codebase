<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@drawable/language_picker_dialog_bg"
    android:layoutDirection="ltr"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/language_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/settings_choose_language"
        android:textColor="#1A1A1A"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:layoutDirection="ltr"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/language_option_en"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <FrameLayout
                android:id="@+id/language_circle_en"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:background="@drawable/language_option_circle_bg"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp">

                <TextView
                    android:id="@+id/language_flag_en"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="36sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/language_label_en"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/language_english"
                android:textColor="#0D3B66"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/language_option_ar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <FrameLayout
                android:id="@+id/language_circle_ar"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:background="@drawable/language_option_circle_bg"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp">

                <TextView
                    android:id="@+id/language_flag_ar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="36sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/language_label_ar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/language_arabic"
                android:textColor="#0D3B66"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/language_option_fr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <FrameLayout
                android:id="@+id/language_circle_fr"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:background="@drawable/language_option_circle_bg"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp">

                <TextView
                    android:id="@+id/language_flag_fr"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="36sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/language_label_fr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/language_french"
                android:textColor="#0D3B66"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@drawable/tts_info_dialog_bg"
    android:layoutDirection="locale"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/dialog_email_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/verify_email_edit_title"
        android:textColor="#1A416B"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto_medium" />

    <TextView
        android:id="@+id/dialog_email_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/verify_email_edit_message"
        android:textColor="#5F6D7B"
        android:textSize="14sp"
        android:fontFamily="@font/roboto_medium" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/dialog_email_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxBackgroundColor="#F4F7FA"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="#DEE5EC"
        app:boxStrokeWidth="1dp"
        app:hintTextColor="#0D3B66"
        app:helperTextTextColor="#E74C3C">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialog_email_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:fontFamily="@font/roboto_medium"
            android:hint="@string/verify_email_edit_hint"
            android:inputType="textEmailAddress"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_email_cancel_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/rubik_medium"
            android:gravity="center"
            android:minHeight="50dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="#2F5A80"
            android:textSize="14sp"
            app:backgroundTint="@android:color/white"
            app:cornerRadius="18dp"
            app:elevation="0dp"
            app:rippleColor="#110D3B66"
            app:strokeColor="#4E7EA8"
            app:strokeWidth="2dp" />

        <View
            android:layout_width="22dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_email_save_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/rubik_medium"
            android:gravity="center"
            android:minHeight="50dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:backgroundTint="#0D3B66"
            app:cornerRadius="18dp"
            app:elevation="0dp"
            app:rippleColor="#FFFFFF3D" />
    </LinearLayout>
</LinearLayout>

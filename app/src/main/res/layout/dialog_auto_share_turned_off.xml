<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    android:background="@drawable/rounded_dialog_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/auto_share_off_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/rubik_medium"
        android:text="@string/settings_auto_share_turned_off_title"
        android:textColor="@color/blue"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/auto_share_off_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/roboto_medium"
        android:lineSpacingExtra="2dp"
        android:text="@string/settings_auto_share_turned_off_message"
        android:textColor="#5F6D7B"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/auto_share_off_ok_button"
        android:layout_width="69dp"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/rubik_medium"
        android:minHeight="40dp"
        android:paddingHorizontal="20dp"
        android:text="OK"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        app:backgroundTint="#0D3B66"
        app:cornerRadius="18dp"
        app:elevation="0dp"
        app:rippleColor="#1AFFFFFF"
        app:strokeWidth="0dp" />

</LinearLayout>
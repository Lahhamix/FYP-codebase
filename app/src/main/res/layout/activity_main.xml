<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EEF1F4"
        android:orientation="vertical">

        <include layout="@layout/toolbar_main" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/wearableDashboardCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/wearable_image"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_alignParentTop="true"
                            android:contentDescription="@string/app_name"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foot_dashboard" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="99dp"
                            android:layout_alignBottom="@id/wearable_image"
                            android:background="@drawable/dashboard_image_shadow" />

                        <include layout="@layout/view_sock_status_overlay" />

                        <View
                            android:id="@+id/disconnected_panel_underlay"
                            android:layout_width="match_parent"
                            android:layout_height="102dp"
                            android:layout_alignTop="@id/wearable_image"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="18dp"
                            android:layout_marginEnd="20dp"
                            android:background="@drawable/disconnected_panel_underlay_bg"
                            android:elevation="7dp"
                            android:translationZ="14dp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/disconnected_panel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignTop="@id/wearable_image"
                            android:layout_marginStart="14dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginEnd="14dp"
                            android:background="@drawable/disconnected_panel_bg"
                            android:elevation="8dp"
                            android:translationZ="16dp"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginEnd="8dp"
                                    android:contentDescription="@string/disconnected"
                                    android:src="@drawable/ic_bluetooth_off" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/rubik_medium"
                                        android:text="@string/sock_disconnected"
                                        android:textColor="#1E2A36"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:fontFamily="@font/rubik_medium"
                                        android:text="@string/sock_disconnected_desc"
                                        android:textColor="#6A7784"
                                        android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal"
                                android:weightSum="2">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/reconnect_inline_button"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_marginEnd="6dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/disconnected_action_button_bg"
                                    android:fontFamily="@font/rubik_medium"
                                    android:minHeight="0dp"
                                    android:paddingHorizontal="8dp"
                                    android:text="@string/reconnect_now"
                                    android:textAllCaps="false"
                                    android:textColor="#1E2A36"
                                    android:textSize="10sp"
                                    app:icon="@drawable/ic_reconnect_refresh_ccw"
                                    app:iconPadding="6dp"
                                    app:iconSize="14dp"
                                    app:iconTint="#1E2A36"
                                    app:strokeWidth="0dp" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/scan_devices_inline_button"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_marginStart="6dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/disconnected_action_button_bg"
                                    android:fontFamily="@font/rubik_medium"
                                    android:minHeight="0dp"
                                    android:paddingHorizontal="8dp"
                                    android:text="@string/scan_devices"
                                    android:textAllCaps="false"
                                    android:textColor="#1E2A36"
                                    android:textSize="10sp"
                                    app:icon="@drawable/ic_scan_devices_radar"
                                    app:iconPadding="6dp"
                                    app:iconSize="14dp"
                                    app:iconTint="#1E2A36"
                                    app:strokeWidth="0dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/vitalSignsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/roboto_medium"
                        android:textStyle="bold"
                        android:text="@string/current_vitals"
                        android:textColor="#3E4D5D"
                        android:textSize="16dp" />

                    <TextView
                        android:id="@+id/seeMoreDetailed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/rubik_medium"
                        android:padding="4dp"
                        android:text="@string/see_more_detailed"
                        android:textColor="#2F6898"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/currentVitalsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/icon_circle_bg"
                                android:foregroundGravity="center">

                            <ImageView
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_heart_rate" />
                            </FrameLayout>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <TextView
                                android:id="@+id/heartStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/status_chip_bg"
                                android:fontFamily="@font/rubik_medium"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="3dp"
                                android:text="@string/dashboard_status_normal"
                                android:textColor="@color/dark_blue"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/roboto_medium"
                            android:text="@string/dashboard_heart_rate_label"
                            android:textColor="#8697A8"
                            android:textSize="12dp" />

                        <TextView
                            android:id="@+id/heartRateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/rubik_medium"
                            android:text="-- BPM"
                            android:textColor="@color/dark_blue"
                            android:textSize="15sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:background="#EC4D75" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/spo2Card"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/icon_circle_bg"
                                    android:foregroundGravity="center">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="SPO2 icon"
                                        android:src="@drawable/ic_spo2" />
                                </FrameLayout>




                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/spo2Status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/status_chip_bg"
                                    android:fontFamily="@font/rubik_medium"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:text="@string/dashboard_status_healthy"
                                    android:textColor="@color/dark_blue"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/rubik_medium"
                                android:text="@string/dashboard_spo2_label"
                                android:textColor="#8697A8"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/spo2Text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/rubik_medium"
                                android:text="-- %"
                                android:textColor="@color/dark_blue"
                                android:textSize="15sp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:layout_marginTop="8dp"
                                android:background="#2D7EEA" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/bpCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/icon_circle_bg"
                                    android:foregroundGravity="center">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="BP icon"
                                        android:src="@drawable/ic_bp_classification" />
                                </FrameLayout>

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/bpStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/status_chip_bg"
                                    android:fontFamily="@font/rubik_medium"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:text="No Backend"
                                    android:textColor="@color/dark_blue"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/roboto_medium"
                                android:text="@string/dashboard_bp_class_label"
                                android:textColor="#8697A8"
                                android:textSize="18dp" />

                            <TextView
                                android:id="@+id/bpText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/rubik_medium"
                                android:text="@string/dashboard_status_normal"
                                android:textColor="@color/dark_blue"
                                android:textSize="12pt" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:layout_marginTop="8dp"
                                android:background="#31567D" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/swellingCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/icon_circle_bg"
                                    android:foregroundGravity="center">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="Swelling icon"
                                        android:src="@drawable/ic_swelling" />
                                </FrameLayout>

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/swellingStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/status_chip_bg"
                                    android:fontFamily="@font/rubik_medium"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                       android:text="@string/dashboard_status_stable"
                                    android:textColor="@color/dark_blue"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/roboto_medium"
                                    android:text="@string/dashboard_swelling_label"
                                android:textColor="#8697A8"
                                android:textSize="18dp" />

                            <TextView
                                android:id="@+id/swellingText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/rubik_medium"
                                android:text="--"
                                android:textColor="@color/dark_blue"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:layout_marginTop="8dp"
                                android:background="#36B8BF" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/ataxiaCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/icon_circle_bg"
                                    android:foregroundGravity="center">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:contentDescription="Ataxia icon"
                                        android:src="@drawable/ic_ataxia" />
                                </FrameLayout>

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1" />

                                <TextView
                                    android:id="@+id/bpStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/status_chip_bg"
                                    android:fontFamily="@font/rubik_medium"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:text="No Backend"
                                    android:textColor="@color/dark_blue"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/roboto_medium"
                                android:text="ATAXIA"
                                android:textColor="#8697A8"
                                android:textSize="18dp" />

                            <TextView
                                android:id="@+id/ataxiaText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/rubik_medium"
                                android:text="Pending"
                                android:textColor="@color/dark_blue"
                                android:textSize="24sp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:layout_marginTop="8dp"
                                android:background="#2D6BC9" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/gaitAnalysisCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="#DEE5EC"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="Assistance alert"
                            android:src="@drawable/ic_circle_alert" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/rubik_medium"
                            android:text="@string/need_assistance"
                            android:textColor="#0D3B66"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sharingExportCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/rubik_medium"
                            android:text="@string/sharing_export"
                            android:textColor="#6A7D91"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/rubik_medium"
                            android:text="@string/sharing_export_desc"
                            android:textColor="#9AABBC"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/share_report_button"
                                android:layout_width="0dp"
                                android:layout_height="92dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/rubik_medium"
                                android:text="@string/share_report"
                                android:textAllCaps="false"
                                android:textColor="@android:color/white"
                                android:textSize="14sp"
                                app:backgroundTint="@color/blue"
                                app:cornerRadius="24dp"
                                app:elevation="0dp"
                                app:icon="@drawable/ic_share_report"
                                app:iconGravity="textTop"
                                app:iconPadding="8dp"
                                app:iconTint="@null"
                                app:rippleColor="#1AFFFFFF"
                                app:strokeWidth="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/download_data_button"
                                android:layout_width="0dp"
                                android:layout_height="92dp"
                                android:layout_marginStart="6dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/rubik_medium"
                                android:text="@string/export_csv"
                                android:textAllCaps="false"
                                android:textColor="#2F5A80"
                                android:textSize="14sp"
                                app:backgroundTint="@android:color/white"
                                app:cornerRadius="24dp"
                                app:elevation="0dp"
                                app:icon="@drawable/ic_export_csv"
                                app:iconGravity="textTop"
                                app:iconPadding="8dp"
                                app:iconTint="@null"
                                app:rippleColor="#110D3B66"
                                app:strokeColor="#4E7EA8"
                                app:strokeWidth="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/pressureMatrixCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:contentDescription="Plantar pressure"
                            android:src="@drawable/ic_pressure_matrix"
                            app:tint="@color/dark_blue" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/rubik_medium"
                                android:text="@string/plantar_pressure"
                                android:textColor="@color/dark_blue"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/rubik_medium"
                                android:text="@string/open_heatmap_calibrate"
                                android:textColor="#7E90A1"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/calibrateButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/rounded_button"
                            android:fontFamily="@font/rubik_medium"
                            android:text="@string/calibrate"
                            android:textAllCaps="false"
                            android:textColor="#003366"
                            android:textSize="14sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:background="@color/white"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:weightSum="3">

            <LinearLayout
                android:id="@+id/nav_history"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/nav_history"
                    android:src="@drawable/ic_nav_history"
                    app:tint="#6B7480" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/rubik_medium"
                    android:gravity="center"
                    android:text="@string/nav_history"
                    android:textColor="#6B7480"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/nav_home"
                    android:src="@drawable/ic_nav_home"
                    app:tint="#3F93E9" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/rubik_medium"
                    android:gravity="center"
                    android:text="@string/nav_home"
                    android:textColor="#3F93E9"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_settings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/nav_settings"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="#6B7480" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/rubik_medium"
                    android:gravity="center"
                    android:text="@string/nav_settings"
                    android:textColor="#6B7480"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <ImageButton
        android:id="@+id/language_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/language_picker_accessibility"
        android:padding="8dp"
        android:src="@drawable/ic_globe"
        app:tint="@color/dark_blue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/logo_card"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_marginTop="36dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="25dp"
        app:cardElevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#E6EDF5"
        app:strokeWidth="1dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.RoundedLogo" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/signup_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/alfaslaboneregular"
        android:text="@string/sign_up_title"
        android:textColor="@color/blue"
        android:textSize="42sp"
        android:gravity="center"
        android:maxLines="2"
        android:textAlignment="center"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo_card" />

    <TextView
        android:id="@+id/subtitle_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/rubik_medium"
        android:text="@string/to_solemate"
        android:textColor="@color/dark_blue"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signup_text" />

    <LinearLayout
        android:id="@+id/form_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="28dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle_text">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/email"
            android:textColor="@color/blue"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/email_edittext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/auth_input_outline"
            android:fontFamily="@font/rubik_medium"
            android:hint="@string/settings_auto_share_dialog_email_hint"
            android:inputType="textEmailAddress"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textColor="@color/dark_blue"
            android:textColorHint="@color/text_hint"
            android:textCursorDrawable="@drawable/text_cursor"
            android:textSize="15sp"
            android:autofillHints="emailAddress" />

        <TextView
            android:id="@+id/email_error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/rubik_light"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/username"
            android:textColor="@color/blue"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/username_edittext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/auth_input_outline"
            android:fontFamily="@font/rubik_medium"
            android:hint="@string/username"
            android:textCursorDrawable="@drawable/text_cursor"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:singleLine="true"
            android:textColor="@color/dark_blue"
            android:textColorHint="@color/text_hint" />

        <TextView
            android:id="@+id/username_error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/rubik_light"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/password"
            android:textColor="@color/blue"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/password_edittext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/auth_input_outline"
            android:drawableEnd="@drawable/ic_eye_closed"
            android:drawablePadding="8dp"
            android:fontFamily="@font/rubik_medium"
            android:gravity="start|center_vertical"
            android:hint="@string/password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textAlignment="viewStart"
            android:textColor="@color/dark_blue"
            android:textColorHint="@color/text_hint"
            android:textCursorDrawable="@drawable/text_cursor"
            android:textDirection="locale"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/password_error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/rubik_light"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/confirm_password"
            android:textColor="@color/blue"
            android:textSize="17sp" />

        <EditText
            android:id="@+id/confirm_password_edittext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/auth_input_outline"
            android:drawableEnd="@drawable/ic_eye_closed"
            android:drawablePadding="8dp"
            android:fontFamily="@font/rubik_medium"
            android:gravity="start|center_vertical"
            android:hint="@string/confirm_password"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textAlignment="viewStart"
            android:textColor="@color/dark_blue"
            android:textColorHint="@color/text_hint"
            android:textCursorDrawable="@drawable/text_cursor"
            android:textDirection="locale"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/confirm_password_error_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/rubik_light"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/register_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:fontFamily="@font/rubik_medium"
        android:text="@string/sign_up"
        android:maxLines="2"
        android:minHeight="48dp"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        app:backgroundTint="@color/blue"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/form_container" />

    <TextView
        android:id="@+id/register_status_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="28dp"
        android:fontFamily="@font/rubik_light"
        android:gravity="center"
        android:textColor="#F44336"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/register_button" />

    <LinearLayout
        android:id="@+id/signin_text_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/register_status_text">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/rubik_light"
            android:text="@string/already_have_account"
            android:textColor="#7A90A7"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/signin_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/sign_in"
            android:textColor="@color/blue"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/or_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="84dp"
        android:layout_marginEnd="84dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signin_text_container">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#C8D4E0" />

        <TextView
            android:id="@+id/or_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:fontFamily="@font/rubik_medium"
            android:text="@string/or"
            android:textColor="#7A90A7"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#C8D4E0" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/google_signup_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:fontFamily="@font/rubik_medium"
        android:text="@string/sign_up_google"
        android:maxLines="2"
        android:minHeight="52dp"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:gravity="center"
        app:backgroundTint="#DB4437"
        app:cornerRadius="24dp"
        app:icon="@drawable/ic_google_white"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/or_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
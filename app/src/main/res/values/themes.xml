<resources>
    <!-- Base application theme. -->
    <style name="Theme.Test" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/background</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorControlActivated">@color/progress_bar_color</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background</item>
        <!-- Use dark status bar icons -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <!-- Theme without an action bar -->
    <style name="Theme.Test.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/background</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background</item>
        <!-- Use dark status bar icons -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="ShapeAppearance.App.CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="CenteredNavDrawerItem" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textAlignment">center</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:fontFamily">@font/rubik_medium</item>
        <item name="android:textColor">@color/dark_blue</item>
    </style>

    <style name="ShapeAppearanceOverlay.RoundedLogo" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">13dp</item>
    </style>

</resources>

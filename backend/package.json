{
  "name": "solemate-backend",
  "version": "2.0.0",
  "private": true,
  "description": "SoleMate full backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/run.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^9.7.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/tests/**/*.test.js"],
    "setupFiles": ["<rootDir>/tests/loadEnv.js"],
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "forceExit": true,
    "maxWorkers": 1,
    "testTimeout": 30000,
    "verbose": true
  },
  "engines": {
    "node": ">=18"
  }
}

PORT=3000
NODE_ENV=development

# PostgreSQL — format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/solemate

# JWT — generate with: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
REFRESH_SECRET=replace-with-a-different-long-random-string
REFRESH_EXPIRES_IN=30d

# Google OAuth — from Google Cloud Console (same Client ID as in google-services.json)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SendGrid
# Set USE_LOCAL_EMAIL=true during local testing to write emails to backend/email_log.txt
USE_LOCAL_EMAIL=true
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=your_verified_sender@example.com
SENDGRID_API_BASE_URL=https://api.sendgrid.com

# File uploads (optional — defaults to ./uploads)
UPLOAD_DIR=uploads
